# Copy this file to .env and fill in your real values.

# Required: get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the model. Defaults to "openai/gpt-4o-mini".
# A few alternatives:
#   openai/gpt-4o-mini                    (cheap, reliable, follows JSON well)
#   anthropic/claude-3-haiku              (cheap, very fast)
#   google/gemini-2.0-flash-exp:free      (free tier, decent quality)
#   meta-llama/llama-3.1-8b-instruct:free (free tier)
OPENROUTER_MODEL=openai/gpt-4o-mini
